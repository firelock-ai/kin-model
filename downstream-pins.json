{
  "crate": "kin-model",
  "registry": "kin",
  "downstream": [
    {
      "repo": "firelock-ai/kin",
      "consumer": "kin (workspace root)",
      "manifest": "Cargo.toml",
      "req": "0.2.0"
    },
    {
      "repo": "firelock-ai/kin-db",
      "consumer": "kin-db",
      "manifest": "crates/kin-db/Cargo.toml",
      "req": "0.2.0"
    },
    {
      "repo": "firelock-ai/kin-bench",
      "consumer": "kin-bench (workspace root)",
      "manifest": "Cargo.toml",
      "req": "0.2.0"
    }
  ]
}
